APP_NAME=FacultyHUB
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────────────────────────────
# Local (WAMP/MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=faculty_lms
DB_USERNAME=root
DB_PASSWORD=

# Production (Render PostgreSQL) — set DB_CONNECTION=pgsql and use Render values

# ─── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Storage ───────────────────────────────────────────────────────────────────
# Local development
FILESYSTEM_DISK=public

# Production (Cloudflare R2 or AWS S3) — set FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=                  # https://<account_id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=                       # public URL for stored files

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@facultyhub.app"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AI (Google Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
